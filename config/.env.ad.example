# Active Directory / LDAP SSO Konfiguration
# Diese Werte in docker-compose.yml als Environment-Variablen setzen
# oder diese Datei als .env.ad umbenennen und per env_file einbinden

AD_ENABLED=true
AD_URL=ldap://dc.example.com
AD_BASE_DN=dc=example,dc=com
AD_BIND_DN=cn=svc-webssh,ou=ServiceAccounts,dc=example,dc=com
AD_BIND_PASSWORD=geheimes-passwort

# LDAP-Filter fuer Benutzersuche ({{username}} wird ersetzt)
AD_USER_FILTER=(sAMAccountName={{username}})

# LDAP-Filter fuer Gruppensuche ({{dn}} wird mit Benutzer-DN ersetzt)
AD_GROUP_FILTER=(member={{dn}})

# Mapping: AD-Gruppenname -> App-Gruppenname (JSON)
# Benutzer bekommen die Standardverbindungen der gemappten App-Gruppen
AD_GROUP_MAP={"AD-Gruppe-Test":"test","AD-Gruppe-Prod":"prod"}

# Standard-Rolle fuer neue AD-Benutzer
AD_DEFAULT_ROLE=user

# AD-Gruppen deren Mitglieder Admin-Rechte bekommen (kommagetrennt)
AD_ADMIN_GROUPS=WebSSH-Admins
